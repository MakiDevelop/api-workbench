{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "API Workbench",
  "version": "0.1.0",
  "identifier": "com.makidevelop.apiworkbench",
  "build": {
    "beforeDevCommand": "npm run desktop:prepare-sidecar && npm run desktop:dev",
    "beforeBuildCommand": "npm run desktop:prepare-sidecar && npm run desktop:build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "API Workbench",
        "width": 1440,
        "height": 940,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "externalBin": [
      "binaries/apiw-sidecar"
    ]
  }
}
